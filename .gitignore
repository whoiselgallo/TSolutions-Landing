# ============================================
# 🧹 TSolutions Landing — .gitignore optimizado
# ============================================

# -----------------------------
# 📦 Node & Vite
# -----------------------------
node_modules/
dist/
build/
.vite/
.vite-cache/
vite.config.local.*

# -----------------------------
# ⚙️ Dependencias y locks
# -----------------------------
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------
# 🧪 Testing
# -----------------------------
coverage/
*.test.js
*.spec.js

# -----------------------------
# 🖼️ Assets temporales
# -----------------------------
*.tmp
*.temp
*.bak
*.cache
*.log

# -----------------------------
# 🧰 IDE / Editor
# -----------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------
# 🪟 Windows
# -----------------------------
Thumbs.db
Desktop.ini

# -----------------------------
# 🔐 Env & credenciales
# -----------------------------
.env
.env.*
!.env.example

# -----------------------------
# 🧱 Build Tools
# -----------------------------
.eslintcache
.stylelintcache
.postcss-cache/

# -----------------------------
# 🖼️ Images generadas
# -----------------------------
*.png.tmp
*.jpg.tmp
*.svg.tmp

# -----------------------------
# 🔄 Git safety
# -----------------------------
# Evita que se suban archivos corruptos dentro de .git
.git/objects/*
.git/index.lock
